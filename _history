 == 20) {\n        d = 12\n        basic.showNumber(d)\n    } else if (d == 12) {\n        d = 10\n        basic.showNumber(d)\n    } else if (d == 10) {\n        d = 8\n        basic.showNumber(d)\n    } else if (d == 8) {\n        d = 6\n        basic.showNumber(d)\n    } else if (d == 6) {\n        d = 4\n        basic.showNumber(d)\n    } else if (d == 4) {\n        d = 100\n        basic.showNumber(d)\n    } else if (d == 100) {\n        d = 20\n        basic.showNumber(d)\n    }\n})\n\nradio.onReceivedString(function (receivedString) {\n    basic.showString(receivedString)\n})\n\nradio.onReceivedNumber(function (receivedNumber) {\n    if (receivedNumber == 2000) {\n        music.play(music.stringPlayable(\"C E G E G B - - \", 400), music.PlaybackMode.UntilDone)\n    }\n    basic.showNumber(receivedNumber)\n})","README.md":"","pxt.json":"{\n    \"name\": \"Dice\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\"\n    ],\n    \"preferredEditor\": \"tsprj\"\n}\n"}},{"timestamp":1778196598646,"editorVersion":"8.0.21","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables><variable id=\"soG[i.Z)ZB,^~_GX!RT)\">d</variable><variable id=\"u}#Vk`,o@S^)LD%*6,52\">roll</variable></variables><block type=\"device_button_event\" x=\"299\" y=\"20\"><field name=\"NAME\">Button.A</field><statement name=\"HANDLER\"><block type=\"controls_if\"><mutation elseif=\"6\"></mutation><value name=\"IF0\"><shadow type=\"logic_boolean\"><field name=\"BOOL\">TRUE</field></shadow><block type=\"logic_compare\"><field name=\"OP\">EQ</field><value name=\"A\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"variables_get\"><field name=\"VAR\" id=\"soG[i.Z)ZB,^~_GX!RT)\">d</field></block></value><value name=\"B\"><shadow type=\"math_number\"><fiel